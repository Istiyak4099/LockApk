<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- DISABLE all backups for security -->
    <!-- EMI locking apps should NOT allow data backup as it could be used to bypass security -->
    <exclude domain="sharedpref" path="." />
    <exclude domain="database" path="." />
    <exclude domain="file" path="." />
    <exclude domain="external" path="." />
</full-backup-content>