<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".LockScreenActivity">

    <!-- Scrollable content for small screens -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <!-- Spacer to push content to center area -->
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- ===== LOCK CARD ===== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="12dp"
                app:cardBackgroundColor="#D32F2F">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="28dp"
                    android:gravity="center_horizontal">

                    <!-- Lock Icon -->
                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@android:drawable/ic_lock_lock"
                        app:tint="@android:color/white"
                        android:contentDescription="Lock icon" />

                    <!-- Title: English -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/your_device_is_locked"
                        android:textColor="@android:color/white"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />



                    <!-- Divider -->
                    <View
                        android:layout_width="80dp"
                        android:layout_height="2dp"
                        android:layout_marginTop="20dp"
                        android:background="#80FFFFFF" />

                    <!-- Message: English -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="@string/lock_message_english"
                        android:textAlignment="center"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />



                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Spacer between cards -->
            <View
                android:layout_width="0dp"
                android:layout_height="20dp" />

            <!-- ===== RETAILER CONTACT CARD ===== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="12dp"
                app:cardBackgroundColor="#C62828">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center_horizontal">

                    <!-- Contact Retailer: English -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/contact_retailer"
                        android:textColor="@android:color/white"
                        android:textSize="17sp"
                        android:textStyle="bold" />



                    <!-- Divider -->
                    <View
                        android:layout_width="40dp"
                        android:layout_height="1dp"
                        android:layout_marginTop="14dp"
                        android:background="#80FFFFFF" />

                    <!-- Phone Number Display -->
                    <TextView
                        android:id="@+id/tvRetailerPhone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/loading_contact"
                        android:textColor="@android:color/white"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:drawablePadding="8dp" />



                    <!-- Call Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCallRetailer"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="18dp"
                        android:text="@string/call_now"
                        android:textColor="#C62828"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:enabled="false"
                        app:backgroundTint="@android:color/white"
                        app:cornerRadius="14dp"
                        app:elevation="6dp"
                        app:rippleColor="#FFCDD2" />



                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Spacer bottom -->
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

        </LinearLayout>
    </ScrollView>

</RelativeLayout>